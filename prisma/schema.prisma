datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Foundation {
  id        String   @id @default("default")
  name      String   @default("YAPCHI Foundation")
  tagline   String   @default("Yayasan Pendidikan Anak Indonesia")
  logoUrl   String?  @default("/images/yapchi_logo.png")
  phone     String?  @default("0812 3456 7890")
  email     String?  @default("info@yapchi.or.id")
  address   String?  @default("Jl. Raya DeKeraton No. 1, Karawang")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schools School[]

  @@map("foundations")
}

model School {
  id           String     @id @default(cuid())
  foundationId String     @default("default")
  foundation   Foundation @relation(fields: [foundationId], references: [id], onDelete: Cascade)
  code         String     @unique // e.g. "dekeraton", "cikarang"
  name         String     // e.g. "TK Smart Kids DeKeraton"
  level        String     @default("TK") // TK, KB, PAUD
  address      String
  phone        String
  logoUrl      String?    @default("/images/smart_kids_logo.png")
  orderIndex   Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  adminUsers        AdminUser[]
  siteProfile       SiteProfile?
  programs          Program[]
  galleryItems      GalleryItem[]
  testimonials      Testimonial[]
  ppdbRegistrations PpdbRegistration[]
  teachers          Teacher[]
  students          Student[]
  schedules         Schedule[]
  announcements     Announcement[]
  leaveRequests     LeaveRequest[]

  @@map("schools")
}

model AdminUser {
  id           String   @id @default(cuid())
  schoolId     String?  // Null means ADMIN_PUSAT for Foundation
  school       School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("ADMIN_PUSAT") // ADMIN_PUSAT, ADMIN_SEKOLAH, GURU, ORTU
  phone        String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model SiteProfile {
  id            String   @id @default(cuid())
  schoolId      String   @unique
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  heroBadge     String   @default("Pendaftaran PPDB 2026/2027 Telah Dibuka!")
  heroTitle     String   @default("Belajar Seru, Tumbuh Bahagia")
  heroSubtitle  String   @default("Bimbingan belajar untuk anak usia 3-8 tahun dengan metode bermain sambil belajar yang menyenangkan")
  heroMascotUrl String   @default("/images/owl_mascot.png")
  ctaTitle      String   @default("Yuk, Daftarkan Si Kecil Sekarang!")
  ctaSubtitle   String   @default("Bergabunglah bersama Smart Kids dan berikan pengalaman belajar terbaik untuk masa depan cerah mereka")
  phone         String   @default("0812 3456 7890")
  instagram     String   @default("smartkids")
  facebook      String   @default("Smart Kids")
  address       String?  @default("DeKeraton, Karawang")
  updatedAt     DateTime @updatedAt

  @@map("site_profiles")
}

model Program {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title      String
  ageRange   String
  iconUrl    String
  features   String   // JSON stringified array of strings
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("programs")
}

model GalleryItem {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title      String
  imageUrl   String
  folder     String   @default("uploads")
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("gallery_items")
}

model Testimonial {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parentName String
  role       String   @default("Orang Tua Siswa")
  initials   String
  content    String
  rating     Int      @default(5)
  bgColor    String   @default("emerald")
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("testimonials")
}

model PpdbRegistration {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  registrationNo String   @unique
  namaAnak       String
  jenisKelamin   String
  agama          String
  tempatLahir    String
  tanggalLahir   String
  usiaAnak       String
  program        String
  namaOrtu       String
  noWhatsapp     String
  email          String
  alamatRumah    String
  docKkUrl       String?
  docAktaUrl     String?
  docFotoUrl     String?
  docKtpUrl      String?
  buktiBayarUrl  String?
  paymentMethod  String   @default("bank")
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("ppdb_registrations")
}

model UploadLog {
  id         String   @id @default(cuid())
  fileName   String
  fileFolder String   // uploads, profile, ppdb
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  createdAt  DateTime @default(now())

  @@map("upload_logs")
}

model Teacher {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name       String
  role       String   // e.g. "Kepala Sekolah", "Wali Kelas Kindergarten", "Guru Pendamping"
  photoUrl   String   @default("/images/teacher_default.png")
  bio        String?  // e.g. "Mendidik dengan kasih sayang"
  education  String?  // e.g. "S1 Pendidikan PAUD"
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("teachers")
}

model Student {
  id              String   @id @default(cuid())
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  nisn            String   @unique
  username        String?  @unique
  passwordHash    String?
  className       String   // e.g. "Kelas TK A"
  gender          String   @default("L") // L / P
  avatarUrl       String   @default("https://i.pravatar.cc/150")
  birthPlaceDate  String
  parentName      String
  parentPhone     String
  parentEmail     String?
  address         String
  attendanceRate  Float    @default(95.0)
  averageGrade    Float    @default(88.5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendances     Attendance[]
  sppRecords      SppRecord[]

  @@map("students")
}

model Schedule {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timeRange   String   // e.g. "08.00 - 09.30"
  className   String   // e.g. "Kelas TK A"
  room        String   // e.g. "Ruang Melati"
  subject     String   // e.g. "Mengenal huruf vokal"
  activities  String   // e.g. "Bernyanyi, menebalkan huruf"
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("schedules")
}

model Attendance {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentName String
  className   String
  status      String   @default("hadir") // hadir, sakit, izin, alfa
  time        String?  // e.g. "07:30"
  reason      String?
  date        String   // e.g. "2026-07-23"
  createdAt   DateTime @default(now())

  @@map("attendances")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherName String
  type        String   @default("izin") // izin, cuti
  startDate   String
  endDate     String
  reason      String
  attachment  String?
  status      String   @default("pending") // pending, disetujui, ditolak
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("leave_requests")
}

model Announcement {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title      String
  content    String
  date       String
  targetRole String   @default("Semua") // Semua, Guru, Siswa
  sender     String   @default("Pengelola Sekolah")
  createdAt  DateTime @default(now())

  @@map("announcements")
}

model SppRecord {
  id          String   @id @default(cuid())
  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentName String
  nisn        String
  className   String
  month       String
  amount      Float    @default(350000)
  status      String   @default("lunas") // lunas, belumLunas, proses
  paymentDate String?
  createdAt   DateTime @default(now())

  @@map("spp_records")
}
